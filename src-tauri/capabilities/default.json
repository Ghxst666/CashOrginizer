{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/cashorg-backend",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            {
              "validator": "\\d+"
            },
            "--data-dir",
            {
              "validator": ".+"
            },
            "--env-file",
            {
              "validator": ".+"
            },
            "--log-level",
            {
              "validator": "trace|debug|info|warn|error"
            }
          ]
        }
      ]
    }
  ]
}
